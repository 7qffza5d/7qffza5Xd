</Base>

<style>
  .page-title {
    font-size: 28px;
    margin-bottom: 24px;
  }

  .prose {
    max-width: var(--measure);
    font-size: 17px;
    color: var(--ink);
  }

    .social-links {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
 
  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    text-decoration: none;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 7px 12px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
 
  .social-links a:hover {
    color: var(--ink);
    border-color: var(--rule-strong);
  }
 
  .social-links svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }
 
  .social-links em {
    font-style: normal;
    color: var(--ink-faint);
  }

</style>
