---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Essays, projects, and notes.' } = Astro.props;
const nav = [
  { href: '/', label: 'Feed' },
  { href: '/essays', label: 'Essays' },
  { href: '/projects', label: 'Projects' },
  { href: '/notebook', label: 'Notebook' },
  { href: '/about', label: 'About' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="wordmark" href="/">7qffza5d</a>
        <nav>
          <ul>
            {nav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built with Astro. &copy; {new Date().getFullYear()}</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .shell {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 32px 0 24px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    text-decoration: none;
    color: var(--ink);
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 20px;
    margin: 0;
    padding: 0;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--ink-soft);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  nav a:hover {
    color: var(--ink);
    border-color: var(--rule-strong);
  }

  main {
    min-height: 60vh;
  }

  .site-footer {
    border-top: 1px solid var(--rule);
    margin-top: 64px;
    padding: 24px 0 48px;
  }

  .site-footer p {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-faint);
    margin: 0;
  }
</style>
